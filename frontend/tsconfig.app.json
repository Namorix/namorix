{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "noEmit": true,
    "paths": {
      "@namorix/core": ["./packages/core/src/index.ts"],
      "@namorix/core/*": ["./packages/core/src/*"],
      "@namorix/ui": ["./packages/ui/src/index.ts"],
      "@namorix/styles": ["./packages/styles/src/index.scss"]
    }
  },
  "include": ["src"]
}
