{
  "name": "@namorix/core",
  "version": "0.31.0",
  "license": "AGPL-3.0-only",
  "author": "IzeroCs",
  "keywords": ["namorix", "desktop", "shell", "types", "auth"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Namorix/namorix.git"
  },
  "bugs": {
    "url": "https://github.com/Namorix/namorix/issues"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "",
    "lint": "eslint ."
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./env": {
      "types": "./src/env/development.ts",
      "development": "./src/env/development.ts",
      "default": "./src/env/production.ts"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "import": "./src/auth/index.ts"
    },
    "./addon": {
      "types": "./src/addon/index.ts",
      "import": "./src/addon/index.ts"
    },
    "./utils": {
      "types": "./src/utils/index.ts",
      "import": "./src/utils/index.ts"
    },
    "./router": {
      "types": "./src/router/index.ts",
      "import": "./src/router/index.ts"
    },
    "./http": {
      "types": "./src/http/index.ts",
      "import": "./src/http/index.ts"
    },
    "./i18n": {
      "types": "./src/i18n/index.ts",
      "import": "./src/i18n/index.ts"
    }
  },
  "dependencies": {
    "react": "19.2.6",
    "react-router-dom": "7.15.1",
    "react-i18next": "17.0.8",
    "i18next": "26.2.0"
  },
  "devDependencies": {
    "@types/react": "19.2.14"
  }
}
